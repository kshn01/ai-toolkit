# Dependencies
node_modules/

# Build output (rebuilt on install via the "prepare" script — no need to commit)
dist/
*.tsbuildinfo

# Test / coverage
coverage/
.vitest/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example

# Editor / OS cruft
.DS_Store
Thumbs.db
*.swp
*~

# Claude Code local (per-developer) settings — keep these out of git.
# A shared .claude/settings.json is fine to commit; the *.local one is personal.
.claude/settings.local.json
