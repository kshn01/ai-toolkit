{
  "name": "ai-workspace-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "ai-workspace": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "ai-workspace": "tsx packages/cli/src/index.ts",
    "build": "tsup",
    "prepare": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
